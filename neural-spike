#!/usr/bin/env python3
"""Spiking Neural Network Screensaver with STDP — pygame version."""
import os
os.environ['PYGAME_HIDE_SUPPORT_PROMPT'] = '1'

import pygame
import math
import random
import sys
import time

random.seed()

# STDP parameters
STDP_A_PLUS = 0.015
STDP_A_MINUS = 0.012
STDP_TAU_PLUS = 20.0
STDP_TAU_MINUS = 25.0
STDP_W_MIN = 0.05
STDP_W_MAX = 1.2

FPS = 30


class Synapse:
    __slots__ = ('source', 'target', 'weight', 'delay')

    def __init__(self, source, target, weight, delay):
        self.source = source
        self.target = target
        self.weight = weight
        self.delay = delay

    def apply_stdp(self):
        dt = self.target.spike_time - self.source.spike_time
        if self.source.spike_time < 0 or self.target.spike_time < 0:
            return
        if dt > 0 and dt < STDP_TAU_PLUS * 3:
            dw = STDP_A_PLUS * math.exp(-dt / STDP_TAU_PLUS)
            self.weight = min(STDP_W_MAX, self.weight + dw)
        elif dt < 0 and -dt < STDP_TAU_MINUS * 3:
            dw = STDP_A_MINUS * math.exp(dt / STDP_TAU_MINUS)
            self.weight = max(STDP_W_MIN, self.weight - dw)


class Neuron:
    __slots__ = ('x', 'y', 'layer', 'inhibitory', 'potential', 'spiking',
                 'spike_time', 'refractory', 'outgoing', 'incoming_buffer',
                 'radius', 'spike_history')

    def __init__(self, x, y, layer, inhibitory=False):
        self.x = x
        self.y = y
        self.layer = layer
        self.inhibitory = inhibitory
        self.potential = 0.0
        self.spiking = False
        self.spike_time = -999
        self.refractory = 0
        self.outgoing = []
        self.incoming_buffer = []
        self.radius = random.uniform(3, 6)
        self.spike_history = []

    def update(self, frame):
        pending = []
        for w, arrival in self.incoming_buffer:
            if frame >= arrival:
                if self.refractory <= 0:
                    self.potential += w
            else:
                pending.append((w, arrival))
        self.incoming_buffer = pending

        if self.refractory > 0:
            self.refractory -= 1
            self.potential *= 0.85
            self.spiking = False
            return False

        if random.random() < 0.015:
            self.potential += random.uniform(0.2, 0.6)

        self.potential *= 0.98

        if self.potential >= 1.0:
            self.spiking = True
            self.spike_time = frame
            self.refractory = random.randint(12, 25)
            self.spike_history.append(frame)
            if len(self.spike_history) > 80:
                self.spike_history.pop(0)

            for syn in self.outgoing:
                w = syn.weight * (-0.5 if self.inhibitory else 1.0)
                syn.target.incoming_buffer.append((w, frame + syn.delay))
                syn.apply_stdp()
            return True

        self.spiking = False
        return False


class SpikePulse:
    __slots__ = ('sx', 'sy', 'tx', 'ty', 'start', 'duration', 'inhibitory', 'active')

    def __init__(self):
        self.active = False

    def init(self, sx, sy, tx, ty, start, duration, inhibitory):
        self.sx, self.sy = sx, sy
        self.tx, self.ty = tx, ty
        self.start = start
        self.duration = duration
        self.inhibitory = inhibitory
        self.active = True

    def progress(self, frame):
        t = (frame - self.start) / self.duration
        if t > 1:
            self.active = False
            return None
        x = self.sx + (self.tx - self.sx) * t
        y = self.sy + (self.ty - self.sy) * t
        alpha = math.sin(t * math.pi)
        return x, y, alpha


def run():
    pygame.init()

    info = pygame.display.Info()
    W, H = info.current_w, info.current_h
    screen = pygame.display.set_mode((W, H), pygame.FULLSCREEN | pygame.NOFRAME)
    pygame.display.set_caption('Spiking Neural Network')
    pygame.mouse.set_visible(False)
    clock = pygame.time.Clock()

    # Create a surface for drawing with alpha
    surf = pygame.Surface((W, H), pygame.SRCALPHA)

    # Font
    try:
        font = pygame.font.Font('/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf', 11)
        font_small = pygame.font.Font('/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf', 9)
        font_title = pygame.font.Font('/usr/share/fonts/truetype/dejavu/DejaVuSansMono-Bold.ttf', 13)
    except:
        font = pygame.font.SysFont('monospace', 11)
        font_small = pygame.font.SysFont('monospace', 9)
        font_title = pygame.font.SysFont('monospace', 13, bold=True)

    # Create neurons
    neurons = []
    layers = 5
    neurons_per_layer = 12
    margin = 60
    for l in range(layers):
        n_in_layer = neurons_per_layer + (2 if l == layers // 2 else 0)
        for n in range(n_in_layer):
            lx = margin + (W - margin * 2) * (l / (layers - 1))
            ly = margin + (H - margin * 2) * ((n + 0.5) / n_in_layer)
            jx = lx + random.uniform(-70, 70)
            jy = ly + random.uniform(-50, 50)
            inhib = random.random() < 0.18
            neurons.append(Neuron(jx, jy, l, inhib))

    # Create synapses
    all_synapses = []
    for n1 in neurons:
        for n2 in neurons:
            if n1 is n2:
                continue
            dx = n2.x - n1.x
            dy = n2.y - n1.y
            d = math.sqrt(dx*dx + dy*dy)
            prob = 0.10
            if n2.layer > n1.layer: prob *= 2.5
            elif n2.layer == n1.layer: prob *= 1.5
            else: prob *= 0.5
            prob *= max(0, 1 - d / (W * 0.65))
            if random.random() < prob:
                weight = random.uniform(0.25, 0.6)
                delay = max(3, int(d * 0.06 + random.uniform(3, 15)))
                syn = Synapse(n1, n2, weight, delay)
                n1.outgoing.append(syn)
                all_synapses.append(syn)

    # Pulse pool
    pulse_pool = [SpikePulse() for _ in range(60)]

    def get_pulse():
        for p in pulse_pool:
            if not p.active:
                return p
        return None

    # Initial stimulation
    for _ in range(6):
        random.choice(neurons).potential = 1.2

    # Colors
    EXC_COLOR = (0, 255, 100)
    INH_COLOR = (255, 70, 50)
    EXC_DIM = (0, 60, 25)
    INH_DIM = (60, 15, 10)

    frame = 0
    total_spikes = 0
    spike_window = []
    last_mouse_pos = None
    mouse_moved_total = 0

    running = True
    while running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False
            elif event.type == pygame.KEYDOWN:
                running = False
            elif event.type == pygame.MOUSEBUTTONDOWN:
                running = False
            elif event.type == pygame.MOUSEMOTION:
                if last_mouse_pos is None:
                    last_mouse_pos = event.pos
                else:
                    dx = abs(event.pos[0] - last_mouse_pos[0])
                    dy = abs(event.pos[1] - last_mouse_pos[1])
                    mouse_moved_total += dx + dy
                    if mouse_moved_total > 50:
                        running = False

        frame += 1

        # Fade: fill with semi-transparent black
        screen.fill((0, 0, 0))
        surf.fill((0, 0, 0, 0))

        # Draw synapses
        for syn in all_synapses:
            norm_w = min(1.0, syn.weight / STDP_W_MAX)
            lw = max(1, int(norm_w * 3))
            alpha = int(15 + norm_w * 35)
            if syn.source.inhibitory:
                color = (min(255, int(15 + norm_w * 50)), int(5 + norm_w * 10), 0, alpha)
            else:
                color = (0, min(255, int(12 + norm_w * 55)), min(255, int(6 + norm_w * 25)), alpha)
            pygame.draw.line(surf, color,
                             (int(syn.source.x), int(syn.source.y)),
                             (int(syn.target.x), int(syn.target.y)), lw)

        # Update neurons
        for n in neurons:
            fired = n.update(frame)
            if fired:
                total_spikes += 1
                spike_window.append(frame)
                for syn in all_synapses:
                    if syn.target is n:
                        syn.apply_stdp()
                # Spawn pulses
                for syn in n.outgoing[:2]:
                    p = get_pulse()
                    if p:
                        dx = syn.target.x - n.x
                        dy = syn.target.y - n.y
                        d = math.sqrt(dx*dx + dy*dy)
                        dur = max(8, int(d * 0.12))
                        p.init(n.x, n.y, syn.target.x, syn.target.y, frame, dur, n.inhibitory)

            # Draw neuron
            age = frame - n.spike_time
            flash = max(0, 1 - age / 12) if age < 12 else 0
            col = INH_COLOR if n.inhibitory else EXC_COLOR
            dim_col = INH_DIM if n.inhibitory else EXC_DIM

            # Glow
            if flash > 0.1:
                glow_r = int(n.radius * 5 * flash)
                glow_alpha = int(flash * 80)
                glow_surf = pygame.Surface((glow_r*2, glow_r*2), pygame.SRCALPHA)
                pygame.draw.circle(glow_surf, (*col, glow_alpha), (glow_r, glow_r), glow_r)
                surf.blit(glow_surf, (int(n.x - glow_r), int(n.y - glow_r)))

            # Soma
            r = int(n.radius + flash * 3)
            alpha_soma = int(100 + flash * 155)
            pygame.draw.circle(surf, (*col, alpha_soma), (int(n.x), int(n.y)), r)

            # Outline
            if flash > 0:
                pygame.draw.circle(surf, (*col, int(flash * 200)),
                                   (int(n.x), int(n.y)), r + 1, 1)
            else:
                p = min(1.0, max(0, n.potential))
                dim_a = int(50 + p * 60)
                pygame.draw.circle(surf, (*dim_col, dim_a), (int(n.x), int(n.y)), int(n.radius))

        # Draw pulses
        for p in pulse_pool:
            if not p.active:
                continue
            result = p.progress(frame)
            if not result:
                continue
            x, y, alpha = result
            col = INH_COLOR if p.inhibitory else EXC_COLOR
            pa = int(alpha * 160)
            pygame.draw.circle(surf, (*col, max(0, pa // 3)), (int(x), int(y)), 5)
            pygame.draw.circle(surf, (*col, max(0, pa)), (int(x), int(y)), 2)

        # HUD
        if frame % 10 == 0:
            spike_window = [t for t in spike_window if frame - t < 120]

        rate = len(spike_window) / 2.0
        weights = [s.weight for s in all_synapses]
        avg_w = sum(weights) / len(weights) if weights else 0
        max_w = max(weights) if weights else 0
        min_w = min(weights) if weights else 0
        strong = sum(1 for w in weights if w > 0.8)
        weak = sum(1 for w in weights if w < 0.15)

        # Title
        title_surf = font_title.render('[ SPIKING NEURAL NETWORK + STDP ]', True, (0, 180, 70))
        title_surf.set_alpha(120)
        surf.blit(title_surf, (25, 12))

        # Clock
        clock_text = time.strftime('%H:%M:%S')
        clock_surf = font.render(clock_text, True, (0, 180, 70))
        clock_surf.set_alpha(100)
        surf.blit(clock_surf, (W - 100, 12))

        # Stats
        stats_lines = [
            f"NEURONS: {len(neurons)}",
            f"SYNAPSES: {len(all_synapses)}",
            f"SPIKE RATE: {rate:.1f} Hz",
            f"TOTAL SPIKES: {total_spikes}",
            f"STDP AVG W: {avg_w:.3f}",
            f"RANGE: [{min_w:.2f} - {max_w:.2f}]",
            f"STRONG: {strong}  WEAK: {weak}",
        ]
        for i, line in enumerate(stats_lines):
            s = font_small.render(line, True, (0, 150, 60))
            s.set_alpha(90)
            surf.blit(s, (25, H - 140 + i * 16))

        # Raster plot
        raster_x, raster_y = W - 230, H - 80
        raster_w, raster_h = 200, 55
        pygame.draw.rect(surf, (0, 15, 0, 120),
                         (raster_x - 2, raster_y - 15, raster_w + 4, raster_h + 18))
        pygame.draw.rect(surf, (0, 80, 30, 80),
                         (raster_x - 2, raster_y - 15, raster_w + 4, raster_h + 18), 1)
        lbl = font_small.render('SPIKE RASTER', True, (0, 150, 60))
        lbl.set_alpha(100)
        surf.blit(lbl, (raster_x, raster_y - 13))

        for ni, n in enumerate(neurons):
            ny = raster_y + (ni / len(neurons)) * raster_h
            for st in n.spike_history[-4:]:
                age = frame - st
                if age < raster_w:
                    sx = raster_x + raster_w - age
                    col = (255, 70, 50) if n.inhibitory else (0, 255, 100)
                    alpha = max(30, 255 - int(age * 2))
                    pygame.draw.line(surf, (*col, alpha),
                                     (int(sx), int(ny)), (int(sx + 1), int(ny + 1)), 1)

        # Blit alpha surface
        screen.blit(surf, (0, 0))

        # Periodic stimulation
        if frame % 25 == 0:
            layer = random.randint(0, layers - 1)
            layer_neurons = [n for n in neurons if n.layer == layer]
            for _ in range(random.randint(2, 5)):
                random.choice(layer_neurons).potential += random.uniform(0.6, 1.1)

        # Global wave
        if frame % 90 == 0:
            for _ in range(random.randint(4, 8)):
                random.choice(neurons).potential = 1.0 + random.uniform(0, 0.3)

        pygame.display.flip()
        clock.tick(FPS)

    pygame.quit()


if __name__ == '__main__':
    run()
